  (:standard
   -open Ppx_yojson_conv_lib.Yojson_conv.Primitives
   -open Account_external_view_models)))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/integration_events/order_accepted_integration_event.atd))
 (targets order_accepted_integration_event_t.ml order_accepted_integration_event_t.mli
          order_accepted_integration_event_j.ml order_accepted_integration_event_j.mli)
 (action
  (progn
   (run atdgen -t -o order_accepted_integration_event %{atd})
