; Generated OCaml protobuf bindings for the vendored Finam Trade-API gRPC
; contracts (subdirectory [proto/] under this adapter). The .proto sources
; are the pure-gRPC contract: the grpc-gateway / google.api.http annotations
; that the public Finam tree carries (for its REST transcoder) have been
; stripped, so codegen needs no descriptor.proto / openapiv2 extension tree.
;
; Codegen runs at build time via [protoc] + the [ocaml-protoc-plugin] driver
; ([protoc-gen-ocaml]). [protoc] must be on PATH (see the adapter ADR);
; [protoc-gen-ocaml] is resolved from the opam switch via %{bin:...}.
;
; All imports are vendored, so [-I .] makes codegen hermetic — no reliance on
; a system protobuf include directory.

(library
 (name finam_grpc_proto)
 (public_name trading.finam_grpc_proto)
 (libraries ocaml-protoc-plugin)
 ; Autogenerated sources: silence the full warning set rather than pollute the
 ; project's strict (warn-error) profile with machine-emitted noise.
 (flags
  (:standard -w -a)))

(rule
 (targets side.ml trade.ml auth_service.ml orders_service.ml
          marketdata_service.ml assets_service.ml accounts_service.ml
          timestamp.ml wrappers.ml decimal.ml interval.ml date.ml money.ml)
 (deps
  (glob_files_rec *.proto))
 (action
  (run
   protoc
   -I
   .
   --plugin=protoc-gen-ocaml=%{bin:protoc-gen-ocaml}
   --ocaml_out=.
   grpc/tradeapi/v1/side.proto
   grpc/tradeapi/v1/trade.proto
   grpc/tradeapi/v1/auth/auth_service.proto
   grpc/tradeapi/v1/orders/orders_service.proto
   grpc/tradeapi/v1/marketdata/marketdata_service.proto
   grpc/tradeapi/v1/assets/assets_service.proto
   grpc/tradeapi/v1/accounts/accounts_service.proto
   google/protobuf/timestamp.proto
   google/protobuf/wrappers.proto
   google/type/decimal.proto
   google/type/interval.proto
   google/type/date.proto
   google/type/money.proto)))
