(library
 (name execution_management_external_integration_events)
 (public_name trading.execution_management.acl.external_integration_events)
 (libraries
  yojson
  ppx_yojson_conv_lib
  atdgen-runtime
  core
  decimal
  datetime
  execution_management
  execution_management_external_view_models
  execution_management_ports
  execution_management_commands)
 (preprocess (pps ppx_yojson_conv))
 (flags
  (:standard
   -open Ppx_yojson_conv_lib.Yojson_conv.Primitives
   -open Execution_management_external_view_models)))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/integration_events/trade_executed_integration_event.atd))
 (targets trade_executed_integration_event_t.ml trade_executed_integration_event_t.mli
          trade_executed_integration_event_j.ml trade_executed_integration_event_j.mli)
 (action
  (progn
   (run atdgen -t -o trade_executed_integration_event %{atd})
   (run atdgen -j -o trade_executed_integration_event %{atd}))))


