(library
 (name paper_broker_commands)
 (public_name trading.paper_broker.commands)
 (libraries
  yojson
  ppx_yojson_conv_lib
  atdgen-runtime
  core
  decimal
  datetime
  paper_broker
  paper_broker_view_models
  paper_broker_integration_events
  paper_broker_domain_event_handlers
  paper_broker_store
  rop)
 (preprocess (pps ppx_yojson_conv))
 (flags
  (:standard
   -open Ppx_yojson_conv_lib.Yojson_conv.Primitives
   -open Paper_broker_view_models)))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/paper_broker/commands/cancel_pending_order_command.atd))
 (targets cancel_pending_order_command_t.ml
          cancel_pending_order_command_t.mli
          cancel_pending_order_command_j.ml
          cancel_pending_order_command_j.mli)
 (action
  (progn
   (run atdgen -t -o cancel_pending_order_command %{atd})
   (run atdgen -j -o cancel_pending_order_command %{atd}))))

; submit_order_command — wire contract shared with broker BC.
; paper_broker is broker's backtest substitute; the substitution
; requires byte-identical wire shape on this command, so both BCs
; regenerate from the same .atd source of truth (broker's, since
; broker is the natural owner of order-submission vocabulary).
; No cross-BC code dependency: generated code is local to this
; library. Cross-ref to Order_kind_view_model resolves against
; Paper_broker_view_models (opened in flags above).
(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/commands/submit_order_command.atd))
 (targets submit_order_command_t.ml
          submit_order_command_t.mli
          submit_order_command_j.ml
          submit_order_command_j.mli)
 (action
  (progn
   (run atdgen -t -o submit_order_command %{atd})
   (run atdgen -j -o submit_order_command %{atd}))))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/paper_broker/commands/apply_bar_command.atd))
 (targets apply_bar_command_t.ml
          apply_bar_command_t.mli
          apply_bar_command_j.ml
          apply_bar_command_j.mli)
 (action
  (progn
   (run atdgen -t -o apply_bar_command %{atd})
   (run atdgen -j -o apply_bar_command %{atd}))))
