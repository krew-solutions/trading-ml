(library
 (name paper_broker_integration_events)
 (public_name trading.paper_broker.integration_events)
 (libraries
  yojson
  ppx_yojson_conv_lib
  atdgen-runtime
  core
  decimal
  datetime
  paper_broker
  paper_broker_view_models)
 (preprocess (pps ppx_yojson_conv))
 (flags
  (:standard
   -open Ppx_yojson_conv_lib.Yojson_conv.Primitives
   -open Paper_broker_view_models)))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/integration_events/order_rejected_integration_event.atd))
 (targets order_rejected_integration_event_t.ml
          order_rejected_integration_event_t.mli
          order_rejected_integration_event_j.ml
          order_rejected_integration_event_j.mli)
 (action
  (progn
   (run atdgen -t -o order_rejected_integration_event %{atd})
   (run atdgen -j -o order_rejected_integration_event %{atd}))))

