(** Why3 companion for [target_proposal.mli] — VO record. Carries no
    behavioural lemmas; structural parity only. *)

module Target_proposal
  use int.Int
  use list.List
  use common.target_position.Target_position as TP

  type book_id
  type instrument

  type t = {
    book_id     : book_id;
    positions   : list TP.t;
    proposed_at : int;
  }
end
