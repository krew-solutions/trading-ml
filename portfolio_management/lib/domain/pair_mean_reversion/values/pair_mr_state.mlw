(** Why3 companion for [pair_mr_state.mli] — opaque state with the
    direction discriminator drawn from the shared
    {!Common.Pair_direction} VO. The structural lemma we expose is
    the hysteresis predicate used by [pair_mean_reversion.mlw]. *)

module Pair_mr_state
  use common.pair_direction.Pair_direction as D

  type t

  function direction_of (s: t) : D.t
end
