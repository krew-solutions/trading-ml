(** Why3 companion for [fill_recorded.mli] — Domain Event record.
    Pure data carrier; no behavioural lemmas. *)

module Fill_recorded
  use int.Int
  use decimal.Decimal

  type book_id
  type instrument

  type t = {
    book_id               : book_id;
    instrument            : instrument;
    new_position_quantity : Decimal.t;
    new_avg_price         : Decimal.t;
    new_cash              : Decimal.t;
    occurred_at           : int;
  }
end
