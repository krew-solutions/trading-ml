(** Why3 companion for [position_recorded.mli] — Domain Event record.
    A pure data carrier: structural, no behavioural lemmas. *)

module Position_recorded
  use int.Int
  use decimal.Decimal

  type book_id
  type instrument

  type t = {
    book_id : book_id;
    instrument : instrument;
    delta_qty : Decimal.t;
    new_qty : Decimal.t;
    occurred_at : int;
  }
end
