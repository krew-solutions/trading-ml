(* Wire contract: broker/lib/application/view_models/instrument_view_model.ml
   AND paper_broker/lib/application/view_models/instrument_view_model.ml.

   Shared by both BCs: paper_broker is broker's backtest substitute
   and must speak the same wire shape. Generated code is local to
   each BC's `*_view_models` library; only this contract is shared.
   No code-level cross-BC dependency. *)

type t = {
  ticker : string;
  venue : string;
  ?isin : string option;
  ?board : string option;
}
