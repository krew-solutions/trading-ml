(library
 (name strategies)
 (public_name trading.strategies)
 (libraries core decimal indicators gbt))

(rule
 (alias why3)
 (deps
  (glob_files *.mlw)
  (glob_files ../core/*.mlw)
  (glob_files ../../../../shared/lib/decimal/*.mlw)
  (glob_files ../indicators/*.mlw))
 (action
  (bash "set -eu
for f in %{deps}; do
  case \"$f\" in ../*) continue ;; esac
  why3 prove -L . -L ../core -L ../../../../shared/lib/decimal -L ../indicators -P alt-ergo \"$f\" >/dev/null 2>&1 \\
    || why3 prove -L . -L ../core -L ../../../../shared/lib/decimal -L ../indicators -P z3 \"$f\" >/dev/null
done")))

(alias
 (name runtest)
 (deps (alias why3)))
